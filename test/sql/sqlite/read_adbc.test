# name: test/sql/sqlite/read_adbc.test
# description: Test the functionality of read_adbc(...)
# group: [sqlite]

require adbc

statement ok
INSTALL sqlite

statement ok
INSTALL httpfs

statement ok
LOAD httpfs

# Create a SQLite DB for penguins
statement ok
ATTACH './test/penguins.sqlite' AS sqlite_db (TYPE sqlite);

# Create the penguins table
statement ok
CREATE TABLE IF NOT EXISTS sqlite_db.penguins AS (
SELECT *
  FROM read_csv('https://blobs.duckdb.org/data/penguins.csv', nullstr = 'NA'))

# Write it out to SQLite
statement ok
DETACH sqlite_db

# Create a convenience macro
statement ok
CREATE OR REPLACE MACRO penguins(query) AS TABLE
    SELECT * FROM read_adbc('profile://./test/penguins.toml', query) 

# Select a constructed boolean column (integer)
query II
SELECT x, typeof(x) 
  FROM penguins('SELECT year > 2000 AS x FROM penguins ORDER BY 1 LIMIT 5')
----
1	BIGINT
1	BIGINT
1	BIGINT
1	BIGINT
1	BIGINT

# Select a single INTEGER column 
query II
SELECT year, typeof(year)
  FROM penguins('SELECT year FROM penguins ORDER BY year LIMIT 5')
----
2007	BIGINT
2007	BIGINT
2007	BIGINT
2007	BIGINT
2007	BIGINT

# Select a single DOUBLE column 
query II
SELECT bill_depth_mm, typeof(bill_depth_mm)
  FROM penguins('SELECT bill_depth_mm FROM penguins ORDER BY bill_depth_mm LIMIT 5')
----
NULL	DOUBLE
NULL	DOUBLE
13.1	DOUBLE
13.2	DOUBLE
13.3	DOUBLE

# Select a single VARCHAR column 
query TT
SELECT species, typeof(species)
  FROM penguins('SELECT species FROM penguins ORDER BY species LIMIT 5')
----
Adelie	VARCHAR
Adelie	VARCHAR
Adelie	VARCHAR
Adelie	VARCHAR
Adelie	VARCHAR

# Select each column from DuckDB
query III
SELECT species, year, bill_depth_mm 
  FROM penguins('SELECT * FROM penguins')
 ORDER BY year, bill_depth_mm, species 
 LIMIT 5
----
Gentoo	2007	13.1
Gentoo	2007	13.2
Gentoo	2007	13.4
Gentoo	2007	13.5
Gentoo	2007	13.5

# Select the columns out of order 
query I R T
SELECT  year, bill_depth_mm, species
  FROM penguins('SELECT * FROM penguins')
 ORDER BY species, bill_depth_mm, year 
 LIMIT 5
----
2008	18.1	Adelie
2008	17.9	Adelie
2009	17.9	Adelie
2007	18.9	Adelie
2008	16.2	Adelie

# Validate the row count
query I
SELECT COUNT(*)
  FROM penguins('SELECT * FROM penguins')
----
344

# Validate distinct counts for each column
query I I I I I I I I
SELECT COUNT(DISTINCT COLUMNS(*))
  FROM penguins('SELECT * FROM penguins')
----
3	3	164	80	55	94	2	3

# Apply projection + filter to the scan 
query T
SELECT DISTINCT species 
  FROM penguins('SELECT * FROM penguins')
 WHERE species NOT LIKE 'A%'
 ORDER BY species
----
Chinstrap
Gentoo

# Filter on non-projected column
query I
SELECT DISTINCT year
  FROM penguins('SELECT * FROM penguins')
 WHERE bill_depth_mm > 21.0
 ORDER BY year
----
2007
2008

# NULL count with NULL filter
query I
SELECT COUNT(*) 
  FROM penguins('SELECT * FROM penguins')
 WHERE bill_depth_mm IS NULL
----
2

# NULL count
query I
SELECT COUNT(*)
  FROM penguins('SELECT * FROM penguins')
 WHERE bill_depth_mm IS NOT NULL
----
342

# NULL in VARCHAR column
query I
SELECT COUNT(*) FROM penguins('SELECT * FROM penguins')
 WHERE sex IS NULL
----
11

# Ensure DOUBLE precision is preserved across the boundary
query I
SELECT COUNT(*) FROM penguins('SELECT * FROM penguins')
 WHERE bill_depth_mm = 13.1
----
1

# Arithmetic on returned numeric columns
query R
SELECT SUM(bill_depth_mm) FROM penguins('SELECT * FROM penguins')
----
5865.9

# Empty result from filter
query T
SELECT species FROM penguins('SELECT * FROM penguins')
 WHERE species = 'NonExistent'
----

# Empty result from LIMIT 0
query I
SELECT COUNT(*) FROM (
  SELECT * FROM penguins('SELECT * FROM penguins LIMIT 0')
)
----
0

# Force multiple Arrow batches by selecting all rows
query I
SELECT COUNT(*) FROM penguins('SELECT * FROM penguins')
----
344

# Verify no rows are duplicated or dropped across batch boundaries
query I
SELECT COUNT(DISTINCT island) FROM penguins('SELECT * FROM penguins')
----
3

# Join ADBC result with local data
query I
SELECT COUNT(*) FROM penguins('SELECT * FROM penguins') p
 JOIN (SELECT UNNEST(['Adelie', 'Gentoo']) AS species) s
   ON p.species = s.species
----
276

# Aggregate across a joined result
query TI
SELECT p.species, COUNT(*) FROM penguins('SELECT * FROM penguins') p
 JOIN (SELECT UNNEST(['Adelie', 'Gentoo']) AS species) s
   ON p.species = s.species
 GROUP BY p.species
 ORDER BY p.species
----
Adelie	152
Gentoo	124

# Verify that two independent streams can run concurrently in a self-join
query I
SELECT COUNT(*) 
  FROM penguins('SELECT * FROM penguins') p1
  JOIN penguins('SELECT * FROM penguins') p2
    ON p1.year = p2.year
----
39496
